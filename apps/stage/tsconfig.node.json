{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "composite": true,

    // Rspeedy uses Node.js's module resolution
    "module": "node16",
    "moduleResolution": "node16",
    "erasableSyntaxOnly": true,

    // Node.js 18+
    "lib": ["ESNext"],
    "target": "ES2022",

    "noEmit": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["lynx.config.ts"]
}
