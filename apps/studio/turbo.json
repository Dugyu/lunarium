{
  "$schema": "https://turbo.build/schema.json",
  "extends": ["//"],
  "tasks": {
    "build": {
      "dependsOn": [
        "@dugyu/luna-studio#build",
        "@dugyu/luna-stage#build",
        "@dugyu/luna-core#build",
        "@dugyu/luna-catalog#build"
      ],
      "inputs": [
        "src/**",
        "public/**",
        "rsbuild.config.ts"
      ],
      "outputs": ["dist/**"]
    }
  }
