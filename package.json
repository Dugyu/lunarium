{
  "name": "@dugyu/lunarium",
  "version": "0.0.0",
  "private": true,
  "description": "The experimental realm of Lynx UI theming.",
  "keywords": [],
  "license": "Apache-2.0",
  "author": "The Lynx Authors",
  "type": "module",
  "scripts": {
    "bootstrap:package": "node tools/bootstrap-package/index.mjs",
    "check:manypkg": "pnpm dlx @manypkg/cli check",
    "check:sherif": "pnpm dlx sherif@latest",
    "demo": "pnpm --filter ./apps/studio demo",
    "fix:all": "pnpm run format && pnpm run fix:manypkg && pnpm run fix:sherif",
    "fix:manypkg": "pnpm dlx @manypkg/cli fix",
    "fix:sherif": "pnpm dlx sherif@latest --fix",
    "format": "dprint fmt",
    "format:check": "dprint check",
    "lint": "biome check .",
    "lint:eslint": "eslint .",
    "lint:eslint:fix": "eslint . --fix",
    "prepare": "husky",
    "release": "turbo run build && changeset publish",
    "stage:build": "turbo run build --filter ./apps/stage",
    "stage:dev": "pnpm --filter ./apps/stage dev",
    "studio:build": "pnpm --filter ./apps/studio build",
    "studio:demo": "pnpm --filter ./apps/studio run demo",
    "studio:dev": "pnpm --filter ./apps/studio dev",
    "studio:preview": "pnpm --filter ./apps/studio preview",
    "test": "turbo run test"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.3",
    "@changesets/cli": "^2.29.8",
    "@cspell/eslint-plugin": "^9.4.0",
    "@eslint/js": "^9.35.0",
    "@eslint/markdown": "^7.2.0",
    "@pnpm/meta-updater": "^2.0.6",
    "@svitejs/changesets-changelog-github-compact": "^1.2.0",
    "@typescript/native-preview": "catalog:ts",
    "@vitest/eslint-plugin": "^1.3.9",
    "cspell": "^9.4.0",
    "dprint": "^0.50.1",
    "eslint": "^9.35.0",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-headers": "^1.3.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-n": "^17.21.3",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.26",
    "eslint-plugin-regexp": "^2.10.0",
    "eslint-plugin-unicorn": "^61.0.2",
    "globals": "^16.3.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.6",
    "sort-package-json": "^3.6.0",
    "turbo": "^2.5.6",
    "typescript": "catalog:ts",
    "typescript-eslint": "^8.43.0"
  },
  "packageManager": "pnpm@10.30.2+sha512.36cdc707e7b7940a988c9c1ecf88d084f8514b5c3f085f53a2e244c2921d3b2545bc20dd4ebe1fc245feec463bb298aecea7a63ed1f7680b877dc6379d8d0cb4",
  "engines": {
    "node": "^22 || ^24"
  }
}
