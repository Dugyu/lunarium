{
  "name": "mtc-color-picker",
  "version": "1.0.0",
  "private": true,
  "description": "Demos comparing BTC, BTC-MTS, and MTC in Lynx.",
  "keywords": [
    "lynx",
    "mtc",
    "btc",
    "btc-mts",
    "reactlynx",
    "color-picker"
  ],
  "author": "The Lynx Authors",
  "type": "module",
  "scripts": {
    "build": "cross-env LYNX_DEMO_BLOCKING_ENABLED=false rspeedy build",
    "demo": "cross-env LYNX_DEMO_BLOCKING_ENABLED=true rspeedy dev",
    "dev": "cross-env LYNX_DEMO_BLOCKING_ENABLED=false rspeedy dev",
    "format": "dprint fmt",
    "format:check": "dprint check",
    "lint": "biome check .",
    "lint:fix": "biome check . --write",
    "preview": "cross-env LYNX_DEMO_BLOCKING_ENABLED=false rspeedy preview"
  },
  "dependencies": {
    "@lynx-js/react": "file:./lynx-js-react-0.112.2.tgz"
  },
  "devDependencies": {
    "@lynx-js/qrcode-rsbuild-plugin": "0.4.1",
    "@lynx-js/react-rsbuild-plugin": "file:./lynx-js-react-rsbuild-plugin-0.10.11.tgz",
    "@lynx-js/rspeedy": "0.10.8",
    "@lynx-js/tailwind-preset": "catalog:tailwind",
    "@lynx-js/types": "catalog:lynx-dev",
    "@rsbuild/plugin-type-check": "catalog:rsbuild",
    "@types/react": "catalog:react18",
    "cross-env": "^10.0.0",
    "rsbuild-plugin-tailwindcss": "catalog:tailwind",
    "tailwindcss": "catalog:tailwind",
    "typescript": "catalog:ts"
  },
  "engines": {
    "node": "^22 || ^24"
  }
}
